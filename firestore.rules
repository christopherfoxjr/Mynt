rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      // Only check if user is in admin emails list
      return isSignedIn() && (request.auth.token.email in ['spoinkosgithub@gmail.com', 'blooper.it@gmail.com', 'blooper.it@gmail.com']);
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User data
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /pots/{potId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /kyc_submissions/{subId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read, write: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Connectivity Test - ALWAYS ALLOWED for debugging
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
